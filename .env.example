# ==========================================================================
# Copy this file to `.env` and fill in the real values.
#   cp .env.example .env
# The `.env` file is in .gitignore and MUST NOT be committed.
# ==========================================================================

# Shared secret configured in the GitHub Webhook
# (Settings -> Webhooks -> Secret). Used to validate the HMAC signature of
# every request. Use a long, random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# GitHub Personal Access Token (classic or fine-grained) with permission to
# read Pull Requests AND write reviews on the test repository.
#   Classic:      "repo" scope (or "public_repo" if the repo is public)
#   Fine-grained: "Contents: Read" and "Pull requests: Read and write"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key, used for the LLM code review.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) Model used for the review. Default: gpt-4o-mini (good cost/quality).
# OPENAI_MODEL=gpt-4o-mini

# (Optional) Minimum severity for a comment to be posted on the PR.
# Values: "low" < "medium" < "high". Default: "medium" (posts medium and high).
# MIN_SEVERITY=medium

# (Optional) GitHub API base URL. Only change for GitHub Enterprise.
# GITHUB_API_URL=https://api.github.com
